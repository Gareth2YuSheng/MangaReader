<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>duck.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="kirbyy.ico" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="duck.ico" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Dapper" Version="2.1.79" />
    <PackageReference Include="Magick.NET-Q8-AnyCPU" Version="14.14.0" />
    <PackageReference Include="Magick.NET.SystemWindowsMedia" Version="8.0.23" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.8" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="kirbyy.ico" />
  </ItemGroup>

</Project>
