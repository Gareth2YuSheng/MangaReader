<UserControl x:Class="MangaReader.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="20,15,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Library" Foreground="White" 
                       FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                <TextBlock Text="Search:" Foreground="LightGray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="SearchBox" Width="150" Height="28" Margin="0,0,15,0" 
                     VerticalContentAlignment="Center" Background="#333" Foreground="White" 
                     BorderThickness="1" BorderBrush="#555" Padding="5,0"
                     TextChanged="SearchBox_TextChanged"/>

                <CheckBox x:Name="FavoritesOnlyCheckbox" Content="My Favorites" Foreground="#FF7A90" FontWeight="Bold"
                          VerticalAlignment="Center" Margin="0,0,15,0" Checked="FilterControls_Changed" Unchecked="FilterControls_Changed"/>

                <TextBlock Text="Status:" Foreground="LightGray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="StatusDropdown" Width="90" Height="28" Margin="0,0,15,0" 
                    VerticalContentAlignment="Center" SelectionChanged="FilterControls_Changed">
                    <ComboBoxItem Content="All" IsSelected="True"/>
                    <ComboBoxItem Content="Unread"/>
                    <ComboBoxItem Content="Read"/>
                </ComboBox>

                <TextBlock Text="Sort:" Foreground="LightGray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="SortDropdown" Width="80" Height="28" Margin="0,0,5,0" 
                    VerticalContentAlignment="Center" SelectionChanged="FilterControls_Changed">
                    <ComboBoxItem Content="Recent" IsSelected="True"/>
                    <ComboBoxItem Content="Name"/>
                </ComboBox>

                <Button x:Name="SortDirectionButton" Content="▼ Desc" Focusable="False" Width="60" Height="28" 
                    Margin="0,0,15,0" Click="SortDirectionButton_Click" ToolTip="Toggle Ascending/Descending"/>

                <TextBlock Text="Tag:" Foreground="LightGray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="TagFilterDropdown" Width="120" Height="28" 
                    VerticalContentAlignment="Center" SelectionChanged="FilterControls_Changed">
                </ComboBox>

                <Button Content="⚙" Click="SettingsButton_Click" Width="30" Margin="5,0"/>
            </StackPanel>
        </Grid>

        <ListBox Grid.Row="1" x:Name="LibraryListBox"
             ItemsSource="{Binding MangaLibrary}" 
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             Background="Transparent" BorderThickness="0" Padding="10"
             MouseDoubleClick="LibraryListBox_MouseDoubleClick"
             PreviewKeyDown="LibraryListBox_PreviewKeyDown">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Width="190" Height="290" Margin="10" CornerRadius="6" ClipToBounds="True"
                        Background="Transparent" 
                        MouseRightButtonUp="MangaCard_MouseRightButtonUp">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="White" Opacity="0.2"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Image Source="{Binding CoverImage}" Stretch="UniformToFill" />

                            <Border HorizontalAlignment="Left" VerticalAlignment="Top" 
                                    Background="#CC28A745" Padding="8,4" Margin="5" CornerRadius="4"
                                    Visibility="{Binding ReadBadgeVisibility}">
                                <TextBlock Text="READ ✓" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>

                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" 
                                    Background="#CC000000" Padding="7,3" Margin="5" CornerRadius="12"
                                    Visibility="{Binding FavoriteBadgeVisibility}">
                                <!--<TextBlock Text="❤" Foreground="#FF4B4B" FontSize="14" FontWeight="Bold" Margin="0,-2,0,0"/>-->
                                <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" 
                                  Fill="#FF4B4B" 
                                  Stretch="Uniform" 
                                  Width="14" 
                                  Height="14"/>
                            </Border>

                            <Border VerticalAlignment="Bottom" Background="#E6222222" Padding="8,12,8,12">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" Foreground="White" 
                                               FontSize="14" FontWeight="SemiBold"
                                               TextAlignment="Center" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="MaxHeight" Value="40"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="MaxHeight" Value="300"/>
                                                        <Setter Property="TextTrimming" Value="None"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <ItemsControl ItemsSource="{Binding TagList}" Margin="0,5,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#4A4A4C" CornerRadius="4" Padding="6,2" Margin="2,2">
                                                    <TextBlock Text="{Binding}" Foreground="#DDDDDD" FontSize="11" FontWeight="Medium"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10,5,10,15">
            <TextBlock Text="Items per page:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
            <ComboBox x:Name="ItemsPerPageDropdown" Width="60" Height="28" Margin="0,0,20,0" 
                      VerticalAlignment="Center" VerticalContentAlignment="Center"
                      SelectionChanged="ItemsPerPageDropdown_SelectionChanged" Focusable="False">
                <ComboBoxItem Content="10"/>
                <ComboBoxItem Content="16"/>
                <ComboBoxItem Content="24" IsSelected="True"/>
                <ComboBoxItem Content="50"/>
            </ComboBox>

            <Button x:Name="LibFirstButton" Content="&lt;&lt;" Focusable="False" Width="70" Height="28" Margin="5" Click="LibFirstButton_Click"/>
            <Button x:Name="LibPrevButton" Content="&lt;" Focusable="False" Width="70" Height="28" Margin="5" Click="LibPrevButton_Click"/>

            <TextBlock x:Name="LibPageIndicator" Text="Page 1 / 59" Foreground="White" VerticalAlignment="Center" Margin="15,0" FontSize="14"/>

            <Button x:Name="LibNextButton" Content="&gt;" Focusable="False" Width="70" Height="28" Margin="5" Click="LibNextButton_Click"/>
            <Button x:Name="LibLastButton" Content="&gt;&gt;" Focusable="False" Width="70" Height="28" Margin="5" Click="LibLastButton_Click"/>
        </StackPanel>

        <Border x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#DC1E1E1E" 
                Visibility="Collapsed" Panel.ZIndex="100">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="250" Height="6" Margin="0,0,0,15" 
                             Foreground="#FF4B4B" Background="#333" BorderThickness="0"/>

                <TextBlock x:Name="LoadingStatusText" Text="Initializing..." 
                           Foreground="White" FontSize="16" FontWeight="SemiBold" 
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>