<Window x:Class="MangaReader.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MangaReader.Views"
        mc:Ignorable="d"
        Title="Settings" Height="200" Width="400" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <TextBlock Text="Manga Root Path:" FontWeight="Bold" Margin="0,0,0,5"/>
        <StackPanel Orientation="Horizontal">
            <TextBox x:Name="PathTextBox" Width="280" Height="25"/>
            <Button Content="..." Width="40" Height="25" Click="BrowseButton_Click" Margin="5,0,0,0"/>
        </StackPanel>
        <Button Content="Save &amp; Close" Click="SaveButton_Click" Margin="0,20,0,0" Height="30"/>
    </StackPanel>
</Window>
