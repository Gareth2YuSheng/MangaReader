<Window x:Class="MangaReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MangaReader.Views" 
        Title="Manga Vault" Height="700" Width="900"
        Icon="/kirbyy.ico"
        WindowState="Maximized"
        PreviewKeyDown="Window_PreviewKeyDown" 
        Background="#1E1E1E">

    <Grid>
        <views:LibraryView x:Name="LibraryComponent" Visibility="Visible" 
                           OnMangaSelected="LibraryComponent_OnMangaSelected"/>

        <views:ReaderView x:Name="ReaderComponent" Visibility="Collapsed" 
                          OnBackRequested="ReaderComponent_OnBackRequested"/>
    </Grid>
</Window>